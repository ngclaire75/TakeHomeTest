{
    "name": "takehome/inaproc-apj-scraper",
    "description": "Scheduled scraper for the INAPROC e-catalog (Alat Penerangan Jalan / APJ) that stores results in PostgreSQL",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
